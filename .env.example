# AirCode Engine Configuration Template
# Copy to .env and populate with your actual credentials

# ============================================================================
# TELEGRAM INTEGRATION
# ============================================================================
# Get from BotFather on Telegram
TELEGRAM_TOKEN=your_bot_token_here
# Your personal chat ID (use @userinfobot to find yours)
TELEGRAM_CHAT_ID=your_chat_id_here
# Restrict webhook commands to your user ID
ALLOWED_USER_ID=your_user_id_here

# ============================================================================
# LLM PROVIDERS
# ============================================================================
# Google Gemini API key (AQ.Ab format for AI Studio)
GEMINI_API_KEY=AQ.Ab_your_key_here
# Alternative: DeepSeek for low-cost utility tasks
DEEPSEEK_API_KEY=sk_your_key_here

# ============================================================================
# LLM ROUTING (Advanced)
# ============================================================================
# Force LiteLLM to use AI Studio instead of Vertex AI
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
# Model to use for code generation
GEMINI_MODEL=gemini/gemini-2.5-pro

# ============================================================================
# LOCAL DEPLOYMENT
# ============================================================================
# Workspace directory (Defaults to a folder inside the current directory)
WORKSPACE_DIR=./workspace
# Path to aider binary (Uses the one in your active virtual environment by default)
AIDER_BIN=aider

# ============================================================================
# TIMEOUTS & LIMITS
# ============================================================================
# Max seconds for aider subprocess execution
AIDER_TIMEOUT=300
# Telegram API request timeout
TELEGRAM_TIMEOUT=10
# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=60

# ============================================================================
# LOGGING
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log format: json or text
LOG_FORMAT=json

# ============================================================================
# ADVANCED TUNING
# ============================================================================
# Auto-commit changes via Git
GIT_AUTO_COMMIT=true
# Max concurrent aider tasks
MAX_CONCURRENT_TASKS=1
# Retry attempts for failed operations
RETRY_ATTEMPTS=3
# Exponential backoff multiplier (retry_delay = base^attempt)
RETRY_BACKOFF_BASE=2.0

# ============================================================================
# TRIAGE ROUTER (Dual-Model Cost Optimization)
# ============================================================================
# Enable intelligent prompt classification and model routing
TRIAGE_ENABLED=true
# DeepSeek classification timeout (seconds)
TRIAGE_TIMEOUT=1.5
# Fallback model if triage fails or canary bypasses (safety default)
TRIAGE_FALLBACK_MODEL=gemini/gemini-2.5-pro
# DeepSeek model for triage classification
DEEPSEEK_MODEL=deepseek-chat

# ============================================================================
# TRIAGE CANARY (Phase 5 — A/B Rollout Control)
# ============================================================================
# What fraction of traffic (0.0–1.0) goes through the triage router.
# Use 0.1 to start with 10% canary, ramp up to 1.0 once stable.
# 1.0 = full traffic through triage (default / production)
# 0.0 = triage completely off (bypass all)
TRIAGE_CANARY_RATE=1.0

# How often (seconds) to auto-send triage stats to Telegram
# 3600 = hourly (default), 86400 = daily, 0 = disable
TRIAGE_STATS_INTERVAL=3600

# ============================================================================
# CLAUDE ROUTING (Phase 6 — Optional Third Model)
# ============================================================================
# Set CLAUDE_API_KEY to enable Claude Haiku for AGENT_GENERATION + QA_TESTING
# Leave blank to keep routing those to Gemini Pro
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-haiku-20241022
